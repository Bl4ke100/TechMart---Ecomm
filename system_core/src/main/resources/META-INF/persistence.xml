<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="techmartPU" transaction-type="JTA">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
        <jta-data-source>java:app/jdbc/techmartDB</jta-data-source>
        
        <class>lk.blake.model.Product</class>
        <class>lk.blake.model.Order</class>
        <class>lk.blake.model.User</class>

        <properties>
            <!-- EclipseLink specific properties for Payara to auto-create schema if needed, but we provided schema.sql -->
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            <property name="eclipselink.logging.level" value="FINE"/>
            
            <!-- Database Connection Optimization & Performance Settings -->
            <!-- We have disabled batch writing because it conflicts with GenerationType.IDENTITY -->
            <property name="eclipselink.cache.shared.default" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
